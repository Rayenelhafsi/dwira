# Production (VPS)
PORT=3001
FRONTEND_URL=https://www.dwiraimmobilier.com
SESSION_SECRET=replace_with_long_random_secret

DB_SOURCE=site
SITE_DB_HOST=127.0.0.1
SITE_DB_PORT=3306
SITE_DB_USER=dwira_user
SITE_DB_PASSWORD=DwiraStrong2026Pass
SITE_DB_NAME=dwira

ADMIN_SEED_EMAIL=admin@dwiraimmobilier.com
ADMIN_SEED_PASSWORD=ChangeMe123!
ADMIN_SEED_NAME=Administrateur

# Frontend API base (used by Vite build)
VITE_API_URL=/api
VITE_CHATBOT_API_URL=https://www.dwiraimmobilier.com/chatbot-api
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_FETCH_BASE_URL=https://www.dwiraimmobilier.com
VITE_PARTNERS_CDN_BASE_URL=
# Transitional mode only. Set true only if DB still has /uploads URLs.
VITE_ENABLE_CLOUDINARY_FETCH=false

# Deploy page links
VITE_OWNER_APP_ANDROID_URL=
VITE_OWNER_APP_IOS_URL=
VITE_ADMIN_APP_ANDROID_URL=
VITE_ADMIN_APP_IOS_URL=

# Backend media upload provider
# auto = prefer R2, then Cloudflare, then Cloudinary, then local disk
MEDIA_UPLOAD_PROVIDER=auto
# When true, /api/upload fails if no remote provider succeeds.
MEDIA_REQUIRED_UPLOAD=true

# Cloudflare R2 object storage (recommended low-cost media storage)
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=

# Cloudflare Images + Stream (recommended for new uploads)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_IMAGES_VARIANT=public
CLOUDFLARE_IMAGES_REQUIRE_SIGNED_URLS=false
# Optional custom player host. If empty, uploads use https://iframe.videodelivery.net/{uid}
CLOUDFLARE_STREAM_CUSTOMER_CODE=

# Backend Cloudinary upload (for /api/upload direct to Cloudinary)
CLOUDINARY_URL=
# Alternative explicit vars (if CLOUDINARY_URL is not used):
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=dwira_uploads
CLOUDINARY_UPLOAD_SOURCE_BASE_URL=https://www.dwiraimmobilier.com
CLOUDINARY_REQUIRED_UPLOAD=false

# Optional OAuth callbacks
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://www.dwiraimmobilier.com/api/auth/google/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=https://www.dwiraimmobilier.com/api/auth/facebook/callback
WEBAUTHN_RP_ID=www.dwiraimmobilier.com
WEBAUTHN_RP_NAME=Dwira Immobilier

# Optional anti-bot (Cloudflare Turnstile free tier)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional Messenger Platform (official)
MESSENGER_VERIFY_TOKEN=
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_APP_SECRET=
MESSENGER_API_VERSION=v21.0

# Optional Meta Pixel + Conversions API
META_CAPI_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
META_CAPI_TEST_EVENT_CODE=
VITE_META_PIXEL_ID=

# Optional email OTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ALLOW_EMAIL_OTP_IN_RESPONSE=0

# Optional phone OTP delivery
OTP_PROVIDER_WEBHOOK_URL=
OTP_PROVIDER_WEBHOOK_SECRET=
ALLOW_OTP_IN_RESPONSE=0

# Optional MyGo hotel partner integration
MYGO_HOTEL_API_BASE_URL=https://admin.mygo.co/api/hotel
MYGO_HOTEL_LOGIN=
MYGO_HOTEL_PASSWORD=

# Optional payment providers for hotel reservation flow
FLOUCI_API_BASE_URL=https://developers.flouci.com/api/v2
FLOUCI_PUBLIC_KEY=
FLOUCI_PRIVATE_KEY=
FLOUCI_WEBHOOK_SECRET=
FLOUCI_AMOUNT_MULTIPLIER=1000
FLOUCI_SESSION_TIMEOUT_SECS=1800

CLICKTOPAY_API_BASE_URL=https://test.clictopay.com/payment/rest
CLICKTOPAY_USERNAME=
CLICKTOPAY_PASSWORD=
CLICKTOPAY_CURRENCY=788
CLICKTOPAY_LANGUAGE=fr
CLICKTOPAY_PAGE_VIEW=DESKTOP
