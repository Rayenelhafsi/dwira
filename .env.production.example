# Optional email OTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ALLOW_EMAIL_OTP_IN_RESPONSE=0

# Optional phone OTP delivery
