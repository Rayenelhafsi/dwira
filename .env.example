# Backend (Node API)
PORT=3001
FRONTEND_URL=http://localhost:5173
SESSION_SECRET=change_me_long_random_secret

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=dwira_local

# Optional remote VPS database used by the sync script
VPS_DB_HOST=
VPS_DB_PORT=3306
VPS_DB_USER=
VPS_DB_PASSWORD=
VPS_DB_NAME=

# Optional admin seed (created at API startup if not exists)
ADMIN_SEED_EMAIL=admin@dwira.local
ADMIN_SEED_PASSWORD=ChangeMe123!
ADMIN_SEED_NAME=Administrateur

# Optional OAuth (leave empty if unused)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:3001/api/auth/facebook/callback
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Dwira Immobilier

# Optional anti-bot (Cloudflare Turnstile free tier)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional Messenger Platform (official)
MESSENGER_VERIFY_TOKEN=
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_APP_SECRET=
MESSENGER_API_VERSION=v21.0

# Frontend API base
VITE_API_URL=http://localhost:3001/api
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_FETCH_BASE_URL=https://www.dwiraimmobilier.com
# Transitional mode only (Cloudinary fetch from origin URLs). Keep false for Cloudinary-only DB.
VITE_ENABLE_CLOUDINARY_FETCH=false

# Backend Cloudinary upload (for /api/upload direct to Cloudinary)
CLOUDINARY_URL=
# Alternative explicit vars (if CLOUDINARY_URL is not used):
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=dwira_uploads
CLOUDINARY_UPLOAD_SOURCE_BASE_URL=https://www.dwiraimmobilier.com
# When true, /api/upload fails if Cloudinary upload fails (no local fallback).
CLOUDINARY_REQUIRED_UPLOAD=true

# Optional phone OTP delivery
OTP_PROVIDER_WEBHOOK_URL=
OTP_PROVIDER_WEBHOOK_SECRET=
ALLOW_OTP_IN_RESPONSE=0

# Optional OpenAI OCR (Vision via Responses API). If empty, local OCR is used.
OPENAI_API_KEY=
OPENAI_OCR_MODEL=gpt-4.1-mini
