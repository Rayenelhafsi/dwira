# Backend (Node API)
PORT=3001
FRONTEND_URL=http://localhost:5173

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=dwira_local

# Optional remote VPS database used by the sync script
VPS_DB_HOST=
VPS_DB_PORT=3306
VPS_DB_USER=
VPS_DB_PASSWORD=
VPS_DB_NAME=

# Optional admin seed (created at API startup if not exists)
ADMIN_SEED_EMAIL=admin@dwira.local
ADMIN_SEED_PASSWORD=ChangeMe123!
ADMIN_SEED_NAME=Administrateur

# Optional OAuth (leave empty if unused)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:3001/api/auth/facebook/callback

# Optional Messenger Platform (official)
MESSENGER_VERIFY_TOKEN=
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_APP_SECRET=
MESSENGER_API_VERSION=v21.0

# Frontend API base
VITE_API_URL=http://localhost:3001/api

# Optional phone OTP delivery
OTP_PROVIDER_WEBHOOK_URL=
OTP_PROVIDER_WEBHOOK_SECRET=
ALLOW_OTP_IN_RESPONSE=0

# Optional OpenAI OCR (Vision via Responses API). If empty, local OCR is used.
OPENAI_API_KEY=
OPENAI_OCR_MODEL=gpt-4.1-mini
