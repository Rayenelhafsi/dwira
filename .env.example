# Backend (Node API)
PORT=3001
FRONTEND_URL=http://localhost:5173
SESSION_SECRET=change_me_long_random_secret

DB_SOURCE=local
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=dwira_local

# Optional remote VPS database used by the sync script
VPS_DB_HOST=
VPS_DB_PORT=3306
VPS_DB_USER=
VPS_DB_PASSWORD=
VPS_DB_NAME=

# Optional explicit site DB (used when DB_SOURCE=site)
SITE_DB_HOST=
SITE_DB_PORT=3306
SITE_DB_USER=
SITE_DB_PASSWORD=
SITE_DB_NAME=

# Optional admin seed (created at API startup if not exists)
ADMIN_SEED_EMAIL=admin@dwiraimmobilier.com
ADMIN_SEED_PASSWORD=Admin12345
ADMIN_SEED_NAME=Super Administrateur

# Optional OAuth (leave empty if unused)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:3001/api/auth/facebook/callback
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_CLIENT_SECRET=
APPLE_REDIRECT_URI=http://localhost:3001/api/auth/apple/callback
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Dwira Immobilier

# Optional anti-bot (Cloudflare Turnstile free tier)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional Messenger Platform (official)
MESSENGER_VERIFY_TOKEN=
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_APP_SECRET=
MESSENGER_API_VERSION=v21.0

# Optional Meta Pixel + Conversions API
META_CAPI_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
META_CAPI_TEST_EVENT_CODE=
VITE_META_PIXEL_ID=

# Frontend API base
VITE_API_URL=http://localhost:3001/api
VITE_CHATBOT_API_URL=http://localhost:8090
VITE_GA_MEASUREMENT_ID=
GA_MEASUREMENT_ID=
GA_PROPERTY_ID=
GA_API_SECRET=
GA_DEBUG_MODE=false
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_FETCH_BASE_URL=https://www.dwiraimmobilier.com
VITE_PARTNERS_CDN_BASE_URL=
# Transitional mode only (Cloudinary fetch from origin URLs). Keep false for Cloudinary-only DB.
VITE_ENABLE_CLOUDINARY_FETCH=false

# Public deploy page links (Firebase Hosting / App Distribution / Store links)
VITE_OWNER_APP_ANDROID_URL=
VITE_OWNER_APP_IOS_URL=
VITE_ADMIN_APP_ANDROID_URL=
VITE_ADMIN_APP_IOS_URL=

# Backend media upload provider
# auto = prefer R2, then Cloudflare, then Cloudinary, then local disk
MEDIA_UPLOAD_PROVIDER=auto
# When true, /api/upload fails if no remote provider succeeds.
MEDIA_REQUIRED_UPLOAD=false

# Cloudflare R2 object storage (recommended low-cost media storage)
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=

# Cloudflare Images + Stream (recommended for new uploads)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# Hosted Images variant to store in DB response (default variant is usually `public`)
CLOUDFLARE_IMAGES_VARIANT=public
CLOUDFLARE_IMAGES_REQUIRE_SIGNED_URLS=false
# Optional custom player host. If empty, uploads use https://iframe.videodelivery.net/{uid}
CLOUDFLARE_STREAM_CUSTOMER_CODE=

# Backend Cloudinary upload (for /api/upload direct to Cloudinary)
CLOUDINARY_URL=
# Alternative explicit vars (if CLOUDINARY_URL is not used):
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=dwira_uploads
CLOUDINARY_UPLOAD_SOURCE_BASE_URL=https://www.dwiraimmobilier.com
# Legacy remote-upload strict mode. Prefer MEDIA_REQUIRED_UPLOAD instead.
CLOUDINARY_REQUIRED_UPLOAD=false

# Optional phone OTP delivery
OTP_PROVIDER_WEBHOOK_URL=
OTP_PROVIDER_WEBHOOK_SECRET=
ALLOW_OTP_IN_RESPONSE=0

# Optional OpenAI OCR (Vision via Responses API). If empty, local OCR is used.
OPENAI_API_KEY=
OPENAI_OCR_MODEL=gpt-4.1-mini

# Optional MyGo hotel partner integration
MYGO_HOTEL_API_BASE_URL=https://admin.mygo.co/api/hotel
MYGO_HOTEL_LOGIN=
MYGO_HOTEL_PASSWORD=

# Optional payment providers for hotel reservation flow
FLOUCI_API_BASE_URL=https://developers.flouci.com/api/v2
FLOUCI_PUBLIC_KEY=
FLOUCI_PRIVATE_KEY=
FLOUCI_WEBHOOK_SECRET=
FLOUCI_AMOUNT_MULTIPLIER=1000
FLOUCI_SESSION_TIMEOUT_SECS=1800

CLICKTOPAY_API_BASE_URL=https://test.clictopay.com/payment/rest
CLICKTOPAY_USERNAME=
CLICKTOPAY_PASSWORD=
CLICKTOPAY_CURRENCY=788
CLICKTOPAY_LANGUAGE=fr
# Keep DESKTOP by default: provider sandbox mobile_payment.html currently breaks on mobile browsers.
CLICKTOPAY_PAGE_VIEW=DESKTOP
CLICKTOPAY_ALLOW_MOBILE_PAGE=false
CLICKTOPAY_CA_CERT_PATH=
CLICKTOPAY_CA_CERT_PEM=

# Optional Firebase Cloud Messaging (owner app push)
# Prefer inline JSON in development:
FIREBASE_SERVICE_ACCOUNT_JSON=
# Or absolute path to service-account JSON file:
FIREBASE_SERVICE_ACCOUNT_PATH=
